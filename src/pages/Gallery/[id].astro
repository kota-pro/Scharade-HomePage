---
export const prerender = false;

import GalleryLayout from "../../layouts/Gallery_Layout.astro";
import { getAlbumPhotos, getAlbums, getAlbumCoverId } from "../../lib/lightroom";

const { id } = Astro.params;
const photos = await getAlbumPhotos(id as string);
let albums: Awaited<ReturnType<typeof getAlbums>> extends (infer U)[]
  ? (U & { coverId: string | null })[]
  : never[] = [];
let apiError = "";

try {
  const rawAlbums = await getAlbums();
  albums = await Promise.all(
    rawAlbums.map(async (album) => {
      const coverId = await getAlbumCoverId(album.id);
      return { ...album, coverId };
    })
  );
} catch (e: any) {
  console.error("[Gallery] Failed to load albums:", e.message);
  apiError = e.message || "アルバムの読み込みに失敗しました";
}

const albumTitle = albums.find((item) => item.id === id)?.payload.name || "Unknown Album";
const ITEMS_PER_PAGE = 100;
---

<GalleryLayout>
  {photos.length === 0 && <div class="no-photos">No photos found.</div>}
  <div class="album-header">
    <p>{albumTitle}</p>
  </div>
  <div class="gallery-container-inner">
    <div class="justified-grid">
      {
        photos.map((photo) => (
          <a
            class="photo-wrapper photo-trigger"
            href={`/api/images/full/${photo.id}`}
            data-lightbox={albumTitle}  
          >
            <img
              src={`/api/images/${photo.id}`}
              alt={photo.name}
              loading="lazy"
              data-full-src={`/api/images/full/${photo.id}`}
            />
            <div class="photo-meta">
              <span class="photo-name">{photo.name}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div id="image-modal" class="modal-overlay" aria-hidden="true">
    <div class="modal-content">
      <button id="modal-close-btn" class="modal-close" aria-label="Close">&times;</button>
      <img id="modal-image" src="" alt="" />
    </div>
  </div>
</GalleryLayout>

<style>
  .album-header {
    margin-bottom: 55px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .album-header p {
    text-align: left;
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: 64px !important;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 9.6px;
  }

  .gallery-container-inner {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  .justified-grid {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    width: 100%;
  }

  .photo-wrapper {
    padding: 0;
    border: none;
    background-color: #f0f0f0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    display: block;
    float: left;
    margin-right: 12px;
    margin-bottom: 12px;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }
  .photo-wrapper.is-loaded {
    opacity: 1;
  }

  .photo-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-meta {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 8px;
    background: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .photo-wrapper:hover .photo-meta {
    opacity: 1;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #modal-image {
    max-width: 100vw;
    max-height: 100vh;
    object-fit: contain;
    box-shadow: none;
  }

  .modal-close {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1100;
    color: white;
    font-size: 40px;
    background: rgba(0, 0, 0, 0.5);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
    border: none;
    cursor: pointer;
  }

  @media screen and (max-width: 780px) {
    .album-header p {
      font-size: 32px !important;
      letter-spacing: 4.8px;
    }

    .modal-close {
      top: 10px;
      right: 10px;
      width: 40px;
      height: 40px;
      font-size: 30px;
    }
  }
</style>

<script>
  const TARGET_HEIGHT = 250;
  const GAP = 12;
  const MIN_LAST_ROW_WIDTH = 800;

  function layoutImages() {
    const container = document.querySelector(".justified-grid") as HTMLElement;
    if (!container) return;

    const containerWidth = container.clientWidth;
    const items = Array.from(
      document.querySelectorAll(".photo-wrapper"),
    ) as HTMLElement[];

    const validItems = items.filter((item) => {
      const img = item.querySelector("img") as HTMLImageElement;
      return img && img.naturalWidth > 0;
    });

    if (validItems.length === 0) return;

    let rows: HTMLElement[][] = [];
    let currentRow: HTMLElement[] = [];
    let currentRowWidth = 0;

    validItems.forEach((item) => {
      const img = item.querySelector("img")!;
      const aspectRatio = img.naturalWidth / img.naturalHeight;
      const itemWidthAtTarget = TARGET_HEIGHT * aspectRatio;

      if (
        currentRowWidth + itemWidthAtTarget + currentRow.length * GAP >
        containerWidth
      ) {
        rows.push(currentRow);
        currentRow = [item];
        currentRowWidth = itemWidthAtTarget;
      } else {
        currentRow.push(item);
        currentRowWidth += itemWidthAtTarget;
      }
    });

    if (currentRow.length > 0) rows.push(currentRow);

    if (rows.length > 0) {
      const lastRow = rows[rows.length - 1];
      let lastRowWidthAtTarget = 0;
      lastRow.forEach((item) => {
        const img = item.querySelector("img")!;
        lastRowWidthAtTarget +=
          (img.naturalWidth / img.naturalHeight) * TARGET_HEIGHT;
      });

      if (lastRowWidthAtTarget < MIN_LAST_ROW_WIDTH && rows.length > 1) {
        const lastRowItems = rows.pop()!;
        rows[rows.length - 1] = rows[rows.length - 1].concat(lastRowItems);
      }
    }

    rows.forEach((row) => {
      let totalAR = 0;
      row.forEach((item) => {
        const img = item.querySelector("img")!;
        totalAR += img.naturalWidth / img.naturalHeight;
      });

      const availableWidth = containerWidth - (row.length - 1) * GAP;
      const rowHeight = availableWidth / totalAR;

      row.forEach((item, itemIndex) => {
        const img = item.querySelector("img")!;
        const ar = img.naturalWidth / img.naturalHeight;

        item.style.width = `${rowHeight * ar}px`;
        item.style.height = `${rowHeight}px`;
        item.style.marginRight =
          itemIndex === row.length - 1 ? "0" : `${GAP}px`;
        item.style.marginBottom = `${GAP}px`;
        item.classList.add("is-loaded");
      });
    });
  }

  // const modal = document.getElementById("image-modal");
  // const modalImg = document.getElementById("modal-image") as HTMLImageElement;
  // const closeBtn = document.getElementById("modal-close-btn");
  // const triggers = document.querySelectorAll(".photo-trigger");

  // function openModal(imgSrc: string, imgAlt: string) {
  //   if (!modal || !modalImg) return;
  //   modalImg.src = imgSrc;
  //   modalImg.alt = imgAlt;
  //   modal.classList.add("active");
  //   modal.setAttribute("aria-hidden", "false");
  //   document.body.style.overflow = "hidden";
  // }

  // function closeModal() {
  //   if (!modal) return;
  //   modal.classList.remove("active");
  //   modal.setAttribute("aria-hidden", "true");
  //   document.body.style.overflow = "";
  //   setTimeout(() => {
  //     if (modalImg) modalImg.src = "";
  //   }, 300);
  // }

  // triggers.forEach((trigger) => {
  //   trigger.addEventListener("click", () => {
  //     const img = trigger.querySelector("img");
  //     if (img) {
  //       const src = img.getAttribute("data-full-src") || img.src;
  //       openModal(src, img.alt);
  //     }
  //   });
  // });

  // closeBtn?.addEventListener("click", closeModal);
  // modal?.addEventListener("click", (e) => {
  //   if (e.target === modal) closeModal();
  // });
  // document.addEventListener("keydown", (e) => {
  //   if (e.key === "Escape" && modal?.classList.contains("active")) closeModal();
  // });

  const allImgs = document.querySelectorAll(".photo-wrapper img");
  let loadedCount = 0;
  allImgs.forEach((img) => {
    const htmlImg = img as HTMLImageElement;
    if (htmlImg.complete) {
      loadedCount++;
    } else {
      htmlImg.addEventListener("load", () => {
        loadedCount++;
        if (loadedCount === allImgs.length) layoutImages();
      });
    }
  });

  if (loadedCount === allImgs.length) layoutImages();

  let resizeTimer: number;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(layoutImages, 100);
  });
  layoutImages();
</script>


<script is:inline define:vars={{ ITEMS_PER_PAGE }}>
  // Pagination logic for tab panels

  const tabInputs = Array.from(
    document.querySelectorAll('.tab-input')
  );
  const tabPanels = Array.from(
    document.querySelectorAll('.tab-panel')
  );

  function setActiveTab(index) {
    tabPanels.forEach((panel, panelIndex) => {
      panel.classList.toggle('is-active', panelIndex === index);
    });
  }

  tabInputs.forEach((input, index) => {
    input.addEventListener('change', () => {
      if (input.checked) setActiveTab(index);
    });
  });

  const initialActiveIndex = tabInputs.findIndex((input) => input.checked);
  setActiveTab(initialActiveIndex >= 0 ? initialActiveIndex : 0);

  document.querySelectorAll(".tab-panel").forEach((panel) => {
    const totalPages = parseInt(panel.getAttribute("data-total-pages") || "1");
    const totalPosts = parseInt(panel.getAttribute("data-total-posts") || "0");

    if (totalPosts === 0) return;

    let currentPage = 1;

    const posts = panel.querySelectorAll(".Activity-item");
    const inputTop = panel.querySelector(".page-input-top");
    const numbersContainer = panel.querySelector(".tab-posts-numbers");

    const btnFirst = panel.querySelector(".first-btn");
    const btnPrev = panel.querySelector(".prev-btn");
    const btnNext = panel.querySelector(".next-btn");
    const btnLast = panel.querySelector(".last-btn");

    const btnPrevTop = panel.querySelector(".prev-btn-top");
    const btnNextTop = panel.querySelector(".next-btn-top");

    const renderPage = (page) => {
      if (page < 1) page = 1;
      if (page > totalPages) page = totalPages;
      currentPage = page;

      const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;

      posts.forEach((post, index) => {
        if (index >= startIndex && index < endIndex) {
          post.style.display = "block";
        } else {
          post.style.display = "none";
        }
      });

      if (inputTop) inputTop.value = currentPage.toString();
      updatePaginationNumbers();
    };

    const updatePaginationNumbers = () => {
      if (!numbersContainer) return;
      numbersContainer.innerHTML = "";

      const pagesSet = new Set([
        1,
        2,
        totalPages - 1,
        totalPages,
        currentPage - 1,
        currentPage,
        currentPage + 1,
      ]);

      const sortedPages = Array.from(pagesSet)
        .filter((p) => p >= 1 && p <= totalPages)
        .sort((a, b) => a - b);

      let prevPage = 0;
      sortedPages.forEach((p) => {
        if (prevPage > 0 && p - prevPage > 1) {
          const dots = document.createElement("span");
          dots.className = "separate-slash";
          dots.textContent = "...";
          numbersContainer.appendChild(dots);
        }

        const a = document.createElement("a");
        a.className = "tab-posts-number";
        a.textContent = p.toString();
        a.href = "#";

        if (p === currentPage) {
          a.style.textDecoration = "underline";
          a.style.textDecorationThickness = "0.5px";
          a.style.textUnderlineOffset = "4px";
        }

        a.addEventListener("click", (e) => {
          e.preventDefault();
          renderPage(p);
        });

        numbersContainer.appendChild(a);
        prevPage = p;
      });
    };

    if (inputTop) {
      inputTop.addEventListener("change", (e) => {
        const val = parseInt(e.target.value);
        if (!isNaN(val)) renderPage(val);
      });
    }

    btnPrevTop?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(currentPage - 1);
    });

    btnNextTop?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(currentPage + 1);
    });

    btnFirst?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(1);
    });

    btnPrev?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(currentPage - 1);
    });

    btnNext?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(currentPage + 1);
    });

    btnLast?.addEventListener("click", (e) => {
      e.preventDefault();
      renderPage(totalPages);
    });

    renderPage(1);
  });
</script>
