---
export const prerender = false;

import GalleryLayout from "../../layouts/Gallery_Layout.astro";
import { getAlbumPhotos, getAlbums, getAlbumCoverId } from "../../lib/lightroom";

const { id } = Astro.params;
const photos = await getAlbumPhotos(id as string);
let albums: Awaited<ReturnType<typeof getAlbums>> extends (infer U)[]
  ? (U & { coverId: string | null })[]
  : never[] = [];
let apiError = "";

try {
  const rawAlbums = await getAlbums();
  albums = await Promise.all(
    rawAlbums.map(async (album) => {
      const coverId = await getAlbumCoverId(album.id);
      return { ...album, coverId };
    })
  );
} catch (e: any) {
  console.error("[Gallery] Failed to load albums:", e.message);
  apiError = e.message || "アルバムの読み込みに失敗しました";
}

const albumTitle = albums.find((item) => item.id === id)?.payload.name || "Unknown Album";
const ITEMS_PER_PAGE = 100;
const totalPages = Math.max(1, Math.ceil(photos.length / ITEMS_PER_PAGE));
---

<GalleryLayout title={albumTitle}>
  {photos.length === 0 &&  <div class="no-photos">No photos found.</div>}
  {photos.length > 0 && (
    <div
      class="tab-panel-number panel-top"
      data-total-posts={photos.length}
      data-total-pages={totalPages}
    >
      <p class="total-pages-label">{photos.length} pictures</p>
      
      {totalPages > 1 && (
        <div class="pagination-controls">
          <a class="tab-posts-navigation prev-btn-top" href="#">
            <img src="/icons/leftarrow.svg" alt="Prev" />
          </a>

          <input
            class="page-input-top"
            type="text"
            inputmode="numeric"
            min="1"
            max={totalPages}
            value="1"
          />
          <p>/</p>
          <p>{totalPages}</p>

          <a class="tab-posts-navigation next-btn-top" href="#">
            <img src="/icons/rightarrow.svg" alt="Next" />
          </a>
        </div>
      )}
    </div>
  )}
  <div class="gallery-container-inner">
    <div class="justified-grid">
      {
        photos.map((photo, photoIndex) => (
          <a
            class="photo-wrapper photo-trigger"
            href={`/api/images/full/${photo.id}`}
            data-lightbox={albumTitle}
            data-index={photoIndex}
          >
            <img
              src={`/api/images/${photo.id}`}
              alt={photo.name}
              decoding="async"
              data-full-src={`/api/images/full/${photo.id}`}
            />
            <div class="photo-meta">
              <span class="photo-name">{photo.name}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
  {photos.length > 0 && totalPages > 1 && (
    <div class="tab-panel-number panel-bottom">
      <a href="#" class="tab-posts-double-navigation first-btn">
        <img src="/icons/doubleleftarrow.svg" alt="First" />
      </a>

      <a href="#" class="tab-posts-navigation prev-btn">
        <img src="/icons/leftarrow.svg" alt="Prev" />
      </a>

      <div class="tab-posts-numbers"></div>

      <a href="#" class="tab-posts-navigation next-btn">
        <img src="/icons/rightarrow.svg" alt="Next" />
      </a>

      <a href="#" class="tab-posts-double-navigation last-btn">
        <img src="/icons/doublerightarrow.svg" alt="Last" />
      </a>
    </div>
  )}

  <div id="image-modal" class="modal-overlay" aria-hidden="true">
    <div class="modal-content">
      <button id="modal-close-btn" class="modal-close" aria-label="Close">&times;</button>
      <img id="modal-image" src="" alt="" />
    </div>
  </div>
</GalleryLayout>

<style>
  .gallery-container-inner {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }

  .tab-panel-number {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 9px;
  }

  .tab-panel-number p,
  .tab-panel-number a,
  .tab-panel-number input {
    color: #000;
    font-family: "Grandiflora One";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
    text-align: center;
    cursor: default;
  }

  .pagination-controls {
    /* width: 100px; */
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .panel-top {
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .panel-bottom {
    justify-content: center;
    margin-top: 24px;
  }

  .page-input-top {
    width: 40px;
    text-align: center;
    border: none;
    background: none;
    outline: none;
    border-bottom: 1px solid #f0f0f0;
    cursor: text !important;
  }

  .page-input-top:focus {
    width: 80px;
    border-bottom: 1px solid #0db49b;
    color: #0db49b !important;
  }

  input.page-input-top::-webkit-outer-spin-button,
  input.page-input-top::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input.page-input-top[type="number"] {
    -moz-appearance: textfield;
  }

  .tab-posts-numbers {
    display: flex;
    gap: 10px;
    margin: 0 15px;
  }

  .tab-posts-number {
    text-decoration: none;
    cursor: pointer !important;
  }

  .tab-posts-number:hover {
    color: #0db49b;
  }

  .tab-posts-navigation {
    text-decoration: none;
    width: 20px;
    height: 20px;
  }

  .tab-posts-double-navigation {
    text-decoration: none;
    width: 26px;
    height: 20px;
  }

  .tab-posts-navigation img,
  .tab-posts-double-navigation img {
    margin-bottom: 2px;
  }

  .tab-posts-navigation:hover {
    filter: invert(56%) sepia(30%) saturate(7333%) hue-rotate(139deg) brightness(100%) contrast(90%);
  }

  .tab-posts-double-navigation:hover {
    filter: invert(56%) sepia(30%) saturate(7333%) hue-rotate(139deg) brightness(100%) contrast(90%);
  }

  .tab-posts-navigation img {
    width: 20px;
    height: 20px;
  }

  .tab-posts-double-navigation img {
    width: 26px;
    height: 20px;
  }


  .justified-grid {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    width: 100%;
  }

  .photo-wrapper {
    padding: 0;
    border: none;
    background-color: #f0f0f0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    display: block;
    float: left;
    margin-right: 12px;
    margin-bottom: 12px;
    opacity: 1;
    transition: opacity 0.5s ease-in-out;
    width: 320px;
    height: 250px;
  }
  .photo-wrapper.is-loaded {
    opacity: 1;
  }

  .photo-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-meta {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 8px;
    background: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .photo-wrapper:hover .photo-meta {
    opacity: 1;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #modal-image {
    max-width: 100vw;
    max-height: 100vh;
    object-fit: contain;
    box-shadow: none;
  }

  .modal-close {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1100;
    color: white;
    font-size: 40px;
    background: rgba(0, 0, 0, 0.5);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
    border: none;
    cursor: pointer;
  }

  @media screen and (max-width: 780px) {
    .tab-panel-number {
      gap: 10px;
      font-size: 14px;
    }

    .tab-posts-numbers {
      gap: 8px;
    }

    .tab-posts-number,
    .separate-slash {
      font-size: 14px;
    }

    .modal-close {
      top: 10px;
      right: 10px;
      width: 40px;
      height: 40px;
      font-size: 30px;
    }
  }
</style>

<script is:inline define:vars={{ ITEMS_PER_PAGE, totalPages }}>
  const TARGET_HEIGHT = 250;
  const GAP = 12;
  const MIN_LAST_ROW_WIDTH = 800;

  function layoutImages() {
    const container = document.querySelector(".justified-grid");
    if (!(container instanceof HTMLElement)) return;

    const containerWidth = container.clientWidth;
    const items = Array.from(
      document.querySelectorAll(".photo-wrapper"),
    ).filter(
      (item) => item instanceof HTMLElement && item.style.display !== "none",
    );

    const validItems = items.filter((item) => {
      const img = item.querySelector("img");
      return img instanceof HTMLImageElement && img.naturalWidth > 0;
    });

    if (validItems.length === 0) return;

    const rows = [];
    let currentRow = [];
    let currentRowWidth = 0;

    validItems.forEach((item) => {
      const img = item.querySelector("img");
      if (!(img instanceof HTMLImageElement)) return;
      const aspectRatio = img.naturalWidth / img.naturalHeight;
      const itemWidthAtTarget = TARGET_HEIGHT * aspectRatio;

      if (
        currentRowWidth + itemWidthAtTarget + currentRow.length * GAP >
        containerWidth
      ) {
        rows.push(currentRow);
        currentRow = [item];
        currentRowWidth = itemWidthAtTarget;
      } else {
        currentRow.push(item);
        currentRowWidth += itemWidthAtTarget;
      }
    });

    if (currentRow.length > 0) rows.push(currentRow);

    if (rows.length > 0) {
      const lastRow = rows[rows.length - 1];
      let lastRowWidthAtTarget = 0;
      lastRow.forEach((item) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        lastRowWidthAtTarget +=
          (img.naturalWidth / img.naturalHeight) * TARGET_HEIGHT;
      });

      if (lastRowWidthAtTarget < MIN_LAST_ROW_WIDTH && rows.length > 1) {
        const lastRowItems = rows.pop();
        if (lastRowItems) {
          rows[rows.length - 1] = rows[rows.length - 1].concat(lastRowItems);
        }
      }
    }

    rows.forEach((row) => {
      let totalAR = 0;
      row.forEach((item) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        totalAR += img.naturalWidth / img.naturalHeight;
      });

      const availableWidth = containerWidth - (row.length - 1) * GAP;
      const rowHeight = availableWidth / totalAR;

      row.forEach((item, itemIndex) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        const ar = img.naturalWidth / img.naturalHeight;

        item.style.width = `${rowHeight * ar}px`;
        item.style.height = `${rowHeight}px`;
        item.style.marginRight =
          itemIndex === row.length - 1 ? "0" : `${GAP}px`;
        item.style.marginBottom = `${GAP}px`;
        item.classList.add("is-loaded");
      });
    });
  }

  function layoutVisibleImagesWhenReady() {
    const visibleItems = Array.from(
      document.querySelectorAll(".photo-wrapper"),
    ).filter(
      (item) => item instanceof HTMLElement && item.style.display !== "none",
    );

    if (visibleItems.length === 0) return;

    const pendingImages = [];

    visibleItems.forEach((item) => {
      const img = item.querySelector("img");
      if (img instanceof HTMLImageElement && !(img.complete && img.naturalWidth > 0)) {
        pendingImages.push(img);
      }
    });

    if (pendingImages.length === 0) {
      layoutImages();
      return;
    }

    let remaining = pendingImages.length;
    pendingImages.forEach((img) => {
      const onDone = () => {
        img.removeEventListener("load", onDone);
        img.removeEventListener("error", onDone);
        remaining -= 1;
        if (remaining === 0) layoutImages();
      };

      img.addEventListener("load", onDone, { once: true });
      img.addEventListener("error", onDone, { once: true });
    });
  }

  // const modal = document.getElementById("image-modal");
  // const modalImg = document.getElementById("modal-image") as HTMLImageElement;
  // const closeBtn = document.getElementById("modal-close-btn");
  // const triggers = document.querySelectorAll(".photo-trigger");

  // function openModal(imgSrc: string, imgAlt: string) {
  //   if (!modal || !modalImg) return;
  //   modalImg.src = imgSrc;
  //   modalImg.alt = imgAlt;
  //   modal.classList.add("active");
  //   modal.setAttribute("aria-hidden", "false");
  //   document.body.style.overflow = "hidden";
  // }

  // function closeModal() {
  //   if (!modal) return;
  //   modal.classList.remove("active");
  //   modal.setAttribute("aria-hidden", "true");
  //   document.body.style.overflow = "";
  //   setTimeout(() => {
  //     if (modalImg) modalImg.src = "";
  //   }, 300);
  // }

  // triggers.forEach((trigger) => {
  //   trigger.addEventListener("click", () => {
  //     const img = trigger.querySelector("img");
  //     if (img) {
  //       const src = img.getAttribute("data-full-src") || img.src;
  //       openModal(src, img.alt);
  //     }
  //   });
  // });

  // closeBtn?.addEventListener("click", closeModal);
  // modal?.addEventListener("click", (e) => {
  //   if (e.target === modal) closeModal();
  // });
  // document.addEventListener("keydown", (e) => {
  //   if (e.key === "Escape" && modal?.classList.contains("active")) closeModal();
  // });

  let resizeTimer = 0;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(layoutVisibleImagesWhenReady, 100);
  });
  const items = Array.from(document.querySelectorAll(".photo-wrapper")).filter(
    (item) => item instanceof HTMLElement,
  );
  const inputTop = document.querySelector(".page-input-top");
  const numbersContainer = document.querySelector(".tab-posts-numbers");
  const btnFirst = document.querySelector(".first-btn");
  const btnPrev = document.querySelector(".prev-btn");
  const btnNext = document.querySelector(".next-btn");
  const btnLast = document.querySelector(".last-btn");
  const btnPrevTop = document.querySelector(".prev-btn-top");
  const btnNextTop = document.querySelector(".next-btn-top");

  let currentPage = 1;

  const renderPage = (page) => {
    if (page < 1) page = 1;
    if (page > totalPages) page = totalPages;
    currentPage = page;

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    items.forEach((item, index) => {
      if (index >= startIndex && index < endIndex) {
        item.style.display = "block";
        item.style.width = "320px";
        item.style.height = `${TARGET_HEIGHT}px`;
        item.style.marginRight = `${GAP}px`;
        item.style.marginBottom = `${GAP}px`;
        item.classList.add("is-loaded");
      } else {
        item.style.display = "none";
      }
    });

    if (inputTop) inputTop.value = currentPage.toString();
    updatePaginationNumbers();
    requestAnimationFrame(layoutVisibleImagesWhenReady);
  };

  const updatePaginationNumbers = () => {
    if (!numbersContainer) return;
    numbersContainer.innerHTML = "";

    const pagesSet = new Set([
      1,
      2,
      totalPages - 1,
      totalPages,
      currentPage - 1,
      currentPage,
      currentPage + 1,
    ]);

    const sortedPages = Array.from(pagesSet)
      .filter((page) => page >= 1 && page <= totalPages)
      .sort((a, b) => a - b);

    let prevPage = 0;
    sortedPages.forEach((page) => {
      if (prevPage > 0 && page - prevPage > 1) {
        const dots = document.createElement("span");
        dots.className = "separate-slash";
        dots.textContent = "...";
        numbersContainer.appendChild(dots);
      }

        const link = document.createElement("a");
        link.className = "tab-posts-number";
        link.textContent = page.toString();
        link.href = "#";

      if (page === currentPage) {
        link.style.textDecoration = "underline";
        link.style.textDecorationThickness = "0.5px";
        link.style.textUnderlineOffset = "4px";
      }

      link.addEventListener("click", (event) => {
        event.preventDefault();
        renderPage(page);
      });

      numbersContainer.appendChild(link);
      prevPage = page;
    });
  };

  inputTop?.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    const value = parseInt(target.value, 10);
    if (!Number.isNaN(value)) renderPage(value);
  });

  btnPrevTop?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage - 1);
  });

  btnNextTop?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage + 1);
  });

  btnFirst?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(1);
  });

  btnPrev?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage - 1);
  });

  btnNext?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage + 1);
  });

  btnLast?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(totalPages);
  });

  renderPage(1);
</script>
