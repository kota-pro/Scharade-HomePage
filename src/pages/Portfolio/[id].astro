---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import { getUserFromRequest } from "../../lib/auth";
import {
  getPortfolios,
  getPortfolioDetail,
  normalizePortfolioGrade,
  type Portfolio,
} from "../../lib/microcms";
import "../../styles/UA+reset.css";

export async function getStaticPaths() {
  const response = await getPortfolios({ fields: ["id"] });
  return response.contents.map((content) => ({
    params: { id: content.id },
  }));
}

const { id } = Astro.params;
const portfolio = await getPortfolioDetail<Portfolio>(id as string);
const gradeText = normalizePortfolioGrade(portfolio.grade);
const genText = portfolio.generation ? `${portfolio.generation}期生` : "";
const hasPictures = portfolio.pictures && portfolio.pictures.length > 0;
const ITEMS_PER_PAGE = 100;
const totalPages = Math.max(
  1,
  Math.ceil((portfolio.pictures?.length ?? 0) / ITEMS_PER_PAGE),
);
const pageTitle = `${portfolio.name} | Portfolio`;
const { user } = getUserFromRequest(Astro.request);
const canEditLink = Boolean(user && user.approved && user.portfolioId === id);

const backLinkMap = {
  portfolio: {
    href: "/Portfolio",
    label: "Portfolioへ戻る",
  },
};
type BackLinkMap = typeof backLinkMap;
type FromParam = keyof BackLinkMap;
const isFromParam = (
  value: string | null,
): value is FromParam => {
  return value !== null && value in backLinkMap;
};
const fromParam = Astro.url.searchParams.get("from");
const backLink = isFromParam(fromParam)
  ? backLinkMap[fromParam]
  : null;
const backLinkMapJSON = JSON.stringify(backLink);
---

<Layout title={pageTitle}>
  <Fragment slot="main-slot">
    <div class="section-title">
      <h1>Portfolio</h1>
      <div class="section-title-line"></div>
    </div>
  </Fragment>

  <Fragment slot="menu-slot">
    <div class="menu-contents-inner">
        <a href="#" class="page-top-nav">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="M16 21.308L6.692 12L16 2.692l1.064 1.064L8.819 12l8.244 8.244z"/></svg>
        </a>
    </div>
  </Fragment>

  <Fragment slot="body-slot">
    <div class="portfolio-detail-wrapper">
      <section class="profile-header">
        <div class="profile-grid">
          <div class="profile-info">
            <div class="name-and-sns">
              <h2 class="user-name">{portfolio.name}</h2>
              <div class="sns">
                {
                  portfolio.x_url && (
                    <a
                      href={portfolio.x_url}
                      target="_blank"
                      class="social-link"
                    >
                      <img src="/icons/X.svg" alt="X">
                    </a>
                  )
                }
                {
                  portfolio.instagram && (
                    <a
                      href={`https://instagram.com/${portfolio.instagram}`}
                      target="_blank"
                      class="social-link"
                    >
                      <img src="/icons/Instagram.svg" alt="Instagram">
                    </a>
                  )
                }
              </div>
            </div>
            <div class="tags">
              {
                portfolio.hashtags?.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))
              }
            </div>
            <p class="camera-info">
              使用機材：{portfolio.camera || "なし"}
            </p>
            <p class="self-introduction">
              {portfolio.self_introduction}
            </p>
          </div>
          <div class="icon">
            <div class="circle">
              <img
                src={portfolio.icon
                  ? portfolio.icon.url
                  : "/images/placeholder_icon.jpeg"}
                alt={portfolio.name}
                class="profile-icon"
              />
              <span
                class="suffix"
                set:html={genText.replace("期", "<br/>期")}
              />
            </div>
            {gradeText && (
              <p class="profile-grade">
                {gradeText}
              </p>
            )}  
          </div>
        </div>
      </section>
    </div>

    <div
      class="back-link"
      id="post-back-link"
      data-map={backLinkMapJSON}
      hidden={!backLink}
    >
      {canEditLink && (
        <div class="edit-link-wrapper">
          <a class="edit-link" href="/Portfolio/edit">Edit my portfolio <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 -2 24 24"><path fill="currentColor" d="M5 19h1.425L16.2 9.225L14.775 7.8L5 17.575zm-2 2v-4.25L17.625 2.175L21.8 6.45L7.25 21zM19 6.4L17.6 5zm-3.525 2.125l-.7-.725L16.2 9.225z"/></svg></a>
        </div>
      )}

      <a href="javascript:history.back()" aria-label="Back">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="25"
          height="25"
          viewBox="0 0 20 20"
        ><path
          fill="currentColor"
          d="M11.25 17.308L5.942 12l5.308-5.308l.708.708L7.364 12l4.594 4.6zm6.1 0L12.042 12l5.308-5.308l.708.708l-4.594 4.6l4.594 4.6z"
        ></path>
        </svg>
        Portfolioへ戻る
      </a>
    </div>

    <hr class="section-divider" />

    {hasPictures && (
      <p class="picture-count">{portfolio.pictures.length} pictures</p>
    )}

    <div class="gallery-container-inner">
      {hasPictures && totalPages > 1 && (
        <div
          class="tab-panel-number panel-top"
          data-total-posts={portfolio.pictures.length}
          data-total-pages={totalPages}
        >
          <p class="total-pages-label">Total {totalPages}</p>

          <a class="tab-posts-navigation prev-btn-top" href="#">
            <img src="/icons/leftarrow.svg" alt="Prev" />
          </a>

          <input
            class="page-input-top"
            type="text"
            inputmode="numeric"
            min="1"
            max={totalPages}
            value="1"
          />
          <p>/</p>
          <p>{totalPages}</p>

          <a class="tab-posts-navigation next-btn-top" href="#">
            <img src="/icons/rightarrow.svg" alt="Next" />
          </a>
        </div>
      )}
      {
        hasPictures ? (
          <div class="justified-grid">
            {portfolio.pictures.map((pic, i) => (
              <a
                class="photo-wrapper"
                href={pic.url}
                data-lightbox={`${portfolio.name}s-works`}
              >
                  <img
                    src={`${pic.url}?w=1200&q=75&fm=webp`}
                    alt={`${portfolio.name}の作品 ${i + 1}`}
                    decoding="async"
                    class="gallery-image"
                  />
              </a>
            ))}
          </div>
        ) : (
          <div class="no-photos"><p>まだ写真が投稿されていません。</p></div>
        )
      }

      {hasPictures && totalPages > 1 && (
        <div class="tab-panel-number panel-bottom">
          <a href="#" class="tab-posts-double-navigation first-btn">
            <img src="/icons/doubleleftarrow.svg" alt="First" />
          </a>

          <a href="#" class="tab-posts-navigation prev-btn">
            <img src="/icons/leftarrow.svg" alt="Prev" />
          </a>

          <div class="tab-posts-numbers"></div>

          <a href="#" class="tab-posts-navigation next-btn">
            <img src="/icons/rightarrow.svg" alt="Next" />
          </a>

          <a href="#" class="tab-posts-double-navigation last-btn">
            <img src="/icons/doublerightarrow.svg" alt="Last" />
          </a>
        </div>
      )}
    </div>
    <div id="image-modal" class="modal-overlay" aria-hidden="true">
      <div class="modal-content">
        <button id="modal-close-btn" class="modal-close" aria-label="Close">&times;</button>
        <img id="modal-image" src="" alt="" />
      </div>
    </div>
  </Fragment>
</Layout>

