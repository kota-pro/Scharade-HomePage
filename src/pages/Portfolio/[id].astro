</style>

<script is:inline define:vars={{ ITEMS_PER_PAGE, totalPages }}>
  const TARGET_HEIGHT = 250;
  const GAP = 12;
  const MIN_LAST_ROW_WIDTH = 800;

  function layoutImages() {
    const container = document.querySelector(".justified-grid");
    if (!(container instanceof HTMLElement)) return;

    const containerWidth = container.clientWidth;
    const items = Array.from(container.querySelectorAll(".photo-wrapper")).filter(
      (item) => item instanceof HTMLElement && item.style.display !== "none",
    );

    const validItems = items.filter((item) => {
      const img = item.querySelector("img");
      return img instanceof HTMLImageElement && img.naturalWidth > 0;
    });

    if (!validItems.length) return;

    let rows = [];
    let currentRow = [];
    let currentRowWidth = 0;

    validItems.forEach((item) => {
      const img = item.querySelector("img");
      if (!(img instanceof HTMLImageElement)) return;

      const aspectRatio = img.naturalWidth / img.naturalHeight;
      const itemWidthAtTarget = TARGET_HEIGHT * aspectRatio;

      if (
        currentRowWidth + itemWidthAtTarget + currentRow.length * GAP >
        containerWidth
      ) {
        rows.push(currentRow);
        currentRow = [item];
        currentRowWidth = itemWidthAtTarget;
      } else {
        currentRow.push(item);
        currentRowWidth += itemWidthAtTarget;
      }
    });

    if (currentRow.length > 0) rows.push(currentRow);

    if (rows.length > 0) {
      const lastRow = rows[rows.length - 1];
      let lastRowWidthAtTarget = 0;

      lastRow.forEach((item) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        lastRowWidthAtTarget +=
          (img.naturalWidth / img.naturalHeight) * TARGET_HEIGHT;
      });

      if (lastRowWidthAtTarget < MIN_LAST_ROW_WIDTH && rows.length > 1) {
        const lastRowItems = rows.pop();
        if (lastRowItems) {
          rows[rows.length - 1] = rows[rows.length - 1].concat(lastRowItems);
        }
      }
    }

    rows.forEach((row, rowIndex) => {
      let totalAR = 0;

      row.forEach((item) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        totalAR += img.naturalWidth / img.naturalHeight;
      });

      const isLastRow = rowIndex === rows.length - 1;
      const availableWidth = containerWidth - (row.length - 1) * GAP;
      const rowHeight = isLastRow ? TARGET_HEIGHT : availableWidth / totalAR;

      row.forEach((item, itemIndex) => {
        const img = item.querySelector("img");
        if (!(img instanceof HTMLImageElement)) return;
        const aspectRatio = img.naturalWidth / img.naturalHeight;

        item.style.width = `${rowHeight * aspectRatio}px`;
        item.style.height = `${rowHeight}px`;
        item.style.marginRight =
          itemIndex === row.length - 1 ? "0" : `${GAP}px`;
        item.style.marginBottom = `${GAP}px`;
        item.classList.add("is-loaded");
      });
    });
  }

  function layoutVisibleImagesWhenReady() {
    const visibleItems = Array.from(
      document.querySelectorAll(".photo-wrapper"),
    ).filter(
      (item) => item instanceof HTMLElement && item.style.display !== "none",
    );

    if (visibleItems.length === 0) return;

    const pendingImages = [];

    visibleItems.forEach((item) => {
      const img = item.querySelector("img");
      if (img instanceof HTMLImageElement && !(img.complete && img.naturalWidth > 0)) {
        pendingImages.push(img);
      }
    });

    if (pendingImages.length === 0) {
      layoutImages();
      return;
    }

    let remaining = pendingImages.length;
    pendingImages.forEach((img) => {
      const onDone = () => {
        img.removeEventListener("load", onDone);
        img.removeEventListener("error", onDone);
        remaining -= 1;
        if (remaining === 0) layoutImages();
      };

      img.addEventListener("load", onDone, { once: true });
      img.addEventListener("error", onDone, { once: true });
    });
  }

  let resizeTimer;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(layoutVisibleImagesWhenReady, 100);
  });

  const items = Array.from(document.querySelectorAll(".photo-wrapper")).filter(
    (item) => item instanceof HTMLElement,
  );
  const inputTop = document.querySelector(".page-input-top");
  const numbersContainer = document.querySelector(".tab-posts-numbers");
  const btnFirst = document.querySelector(".first-btn");
  const btnPrev = document.querySelector(".prev-btn");
  const btnNext = document.querySelector(".next-btn");
  const btnLast = document.querySelector(".last-btn");
  const btnPrevTop = document.querySelector(".prev-btn-top");
  const btnNextTop = document.querySelector(".next-btn-top");

  let currentPage = 1;

  const renderPage = (page) => {
    if (page < 1) page = 1;
    if (page > totalPages) page = totalPages;
    currentPage = page;

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    items.forEach((item, index) => {
      if (index >= startIndex && index < endIndex) {
        item.style.display = "block";
        item.style.width = "320px";
        item.style.height = `${TARGET_HEIGHT}px`;
        item.style.marginRight = `${GAP}px`;
        item.style.marginBottom = `${GAP}px`;
        item.classList.add("is-loaded");
      } else {
        item.style.display = "none";
      }
    });

    if (inputTop) inputTop.value = currentPage.toString();
    updatePaginationNumbers();
    requestAnimationFrame(layoutVisibleImagesWhenReady);
  };

  const updatePaginationNumbers = () => {
    if (!numbersContainer) return;
    numbersContainer.innerHTML = "";

    const pagesSet = new Set([
      1,
      2,
      totalPages - 1,
      totalPages,
      currentPage - 1,
      currentPage,
      currentPage + 1,
    ]);

    const sortedPages = Array.from(pagesSet)
      .filter((page) => page >= 1 && page <= totalPages)
      .sort((a, b) => a - b);

    let prevPage = 0;
    sortedPages.forEach((page) => {
      if (prevPage > 0 && page - prevPage > 1) {
        const dots = document.createElement("span");
        dots.className = "separate-slash";
        dots.textContent = "...";
        numbersContainer.appendChild(dots);
      }

      const link = document.createElement("a");
      link.className = "tab-posts-number";
      link.textContent = page.toString();
      link.href = "#";

      if (page === currentPage) {
        link.style.textDecoration = "underline";
        link.style.textDecorationThickness = "0.5px";
        link.style.textUnderlineOffset = "4px";
      }

      link.addEventListener("click", (event) => {
        event.preventDefault();
        renderPage(page);
      });

      numbersContainer.appendChild(link);
      prevPage = page;
    });
  };

  inputTop?.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    const value = parseInt(target.value, 10);
    if (!Number.isNaN(value)) renderPage(value);
  });

  btnPrevTop?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage - 1);
  });

  btnNextTop?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage + 1);
  });

  btnFirst?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(1);
  });

  btnPrev?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage - 1);
  });

  btnNext?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(currentPage + 1);
  });

  btnLast?.addEventListener("click", (event) => {
    event.preventDefault();
    renderPage(totalPages);
  });

  if (items.length > 0) {
    renderPage(1);
  }
</script>
