    #tab1:checked ~ label[for="tab1"],
    #tab2:checked ~ label[for="tab2"],
    #tab3:checked ~ label[for="tab3"],
    #tab4:checked ~ label[for="tab4"],
    #tab5:checked ~ label[for="tab5"] {
        background-color: #fff;
        border-color: #000000;
        border-style: solid;
        border-width: 1px 1px 0px 1px;
        border-radius: 2px 2px 0px 0px;
        color: #0db49b;
    }

    #tab1:checked ~ label[for="tab1"] + div,
    #tab2:checked ~ label[for="tab2"] + div,
    #tab3:checked ~ label[for="tab3"] + div,
    #tab4:checked ~ label[for="tab4"] + div,
    #tab5:checked ~ label[for="tab5"] + div {
        display: flex;
        background-color: #fff;
    }

    #tab1:checked ~ label[for="tab1"] + div::after,
    #tab2:checked ~ label[for="tab2"] + div::after,
    #tab3:checked ~ label[for="tab3"] + div::after,
    #tab4:checked ~ label[for="tab4"] + div::after,
    #tab5:checked ~ label[for="tab5"] + div::after {
        content: '';
        display: block;
        width: 100%;
        height: 1px;
        background: #000;
        position: absolute;
        top: 100%;
        left: 0;
    }

    .tab > label[for="tab5"],
    .tab > input#tab5 + label,
    .tab > input#tab5 + label + div {
        display: none;
    }

