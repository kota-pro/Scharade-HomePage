---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getUserFromRequest } from "../../lib/auth";
import {
  getPortfolios,
  getPortfolioDetail,
  type Portfolio,
} from "../../lib/microcms";
import "../../styles/UA+reset.css";

export async function getStaticPaths() {
  const response = await getPortfolios({ fields: ["id"] });
  return response.contents.map((content) => ({
    params: { id: content.id },
  }));
}

const { id } = Astro.params;
const portfolio = await getPortfolioDetail<Portfolio>(id as string);
const genText = portfolio.generation ? `${portfolio.generation}期生` : "";
const hasPictures = portfolio.pictures && portfolio.pictures.length > 0;
const pageTitle = `${portfolio.name} | Portfolio`;
const { user } = getUserFromRequest(Astro.request);
const canEditLink = Boolean(user && user.approved && user.portfolioId === id);

const backLinkMap = {
  portfolio: {
    href: "/Portfolio",
    label: "Portfolioへ戻る",
  },
};
type BackLinkMap = typeof backLinkMap;
type FromParam = keyof BackLinkMap;
const isFromParam = (
  value: string | null,
): value is FromParam => {
  return value !== null && value in backLinkMap;
};
const fromParam = Astro.url.searchParams.get("from");
const backLink = isFromParam(fromParam)
  ? backLinkMap[fromParam]
  : null;
const backLinkMapJSON = JSON.stringify(backLink);
---

<Layout title={pageTitle}>
  <Fragment slot="main-slot">
    <div class="section-title">
      <h1>Portfolio</h1>
      <div class="section-title-line"></div>
    </div>
  </Fragment>

  <Fragment slot="menu-slot">
    <div class="menu-contents-inner">
        <a href="#" class="page-top-nav">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="M16 21.308L6.692 12L16 2.692l1.064 1.064L8.819 12l8.244 8.244z"/></svg>
        </a>
    </div>
  </Fragment>

  <Fragment slot="body-slot">
    <div class="portfolio-detail-wrapper">
      <section class="profile-header">
        <div class="profile-grid">
          <div class="profile-info">
            <h2 class="user-name">{portfolio.name}</h2>
            <div class="tags">
              {
                portfolio.hashtags?.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))
              }
            </div>
            <p class="camera-info">
              使用機材：{portfolio.camera || "なし"}
            </p>
            <p class="self-introduction">
              {portfolio.self_introduction}
            </p>
            <div class="social-links">
              {
                portfolio.x_url && (
                  <a href={portfolio.x_url} target="_blank" class="social-link">
                    X
                  </a>
                )
              }
              {
                portfolio.instagram && (
                  <a
                    href={`https://instagram.com/${portfolio.instagram}`}
                    target="_blank"
                    class="social-link"
                  >
                    Instagram
                  </a>
                )
              }
            </div>
          </div>
          <div class="icon">
            <div class="circle">
              <img
                src={portfolio.icon
                  ? portfolio.icon.url
                  : "/images/placeholder_icon.jpeg"}
                alt={portfolio.name}
                class="profile-icon"
              />
              <span
                class="suffix"
                set:html={genText.replace("期", "<br/>期")}
              />
            </div>
            {portfolio.grade && (
              <p class="profile-grade">
                {portfolio.grade}
              </p>
            )}
          </div>
        </div>
      </section>
    </div>

    {canEditLink && (
    <div class="edit-link-wrapper">
        <a class="edit-link" href="/portfolio/edit">Edit my portfolio</a>
    </div>
    )}

    <div
      class="back-link"
      id="post-back-link"
      data-map={backLinkMapJSON}
      hidden={!backLink}
    >
      <a href="javascript:history.back()" class="page-top-nav" aria-label="Back">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="25"
          height="25"
          viewBox="0 0 20 20"
          ><path
            fill="currentColor"
            d="M11.25 17.308L5.942 12l5.308-5.308l.708.708L7.364 12l4.594 4.6zm6.1 0L12.042 12l5.308-5.308l.708.708l-4.594 4.6l4.594 4.6z"
          ></path>
        </svg>
      </a>
    </div>

    <hr class="section-divider" />

    <div class="gallery-container-inner">
      {
        hasPictures ? (
          <div class="picture-grid">
            {portfolio.pictures.map((pic, i) => (
              <div class="photo-card">
                <div class="photo-wrapper">
                  <img
                    src={`${pic.url}?w=1200&q=75&fm=webp`}
                    alt={`${portfolio.name}の作品 ${i + 1}`}
                    loading="lazy"
                    class="gallery-image"
                  />
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="no-photos">まだ写真が投稿されていません。</div>
        )
      }
    </div>

    <div id="image-modal" class="modal-overlay" aria-hidden="true">
      <div class="modal-content">
        <button id="modal-close-btn" class="modal-close" aria-label="Close"
          >&times;</button
        >
        <img id="modal-image" src="" alt="" />
      </div>
    </div>
  </Fragment>
</Layout>

<script>

  const modal = document.getElementById("image-modal");
  const modalImg = document.getElementById("modal-image") as HTMLImageElement;
  const closeBtn = document.getElementById("modal-close-btn");

  document.querySelectorAll(".gallery-image").forEach((img) => {
    img.addEventListener("click", () => {
      if (!modal || !modalImg) return;
      const src = img.getAttribute("src")?.split("?")[0];
      if (src) {
        modalImg.src = src;
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    });
  });

  closeBtn?.addEventListener("click", () => {
    modal?.classList.remove("active");
    document.body.style.overflow = "";
  });

  const container = document.getElementById("post-back-link");
  if (container) {
    try {
      const map = JSON.parse(container.dataset.map ?? "{}");
      const params = new URLSearchParams(window.location.search);
      const from = params.get("from");
      const link = from && map[from];
      if (link) {
        if (!container.querySelector("a")) {
          const anchor = document.createElement("a");
          anchor.href = link.href;
          anchor.textContent = link.label;
          container.appendChild(anchor);
        }
        container.hidden = false;
      } else {
        container.hidden = true;
      }
    } catch (error) {
      console.error("Failed to render back link", error);
    }
  }

</script>

<style>
  .section-title {
    display: flex;
    flex-direction: row;
    align-items: space-between;
    justify-content: center;
    margin-bottom: 55px;
  }

  .section-title h1 {
    color: #000;
    font-family: "Didot";
    font-size: 96px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 14.4px;
    padding-right: 78px;
  }

  .section-title-line {
    width: 100%;
    position: relative;
  }

  .section-title-line::after {
    content: '';
    display: block;
    width: 100%;
    height: 1px;
    background: #000;
    position: absolute;
    top: 50%;
    right: 0;
  }

  .menu-contents-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .page-top-nav {
    width: 50px;
    height: 50px;
    background-color: #fff;
    border: 1px solid #000;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: sticky;
    bottom: 50px;
    z-index: 5;
    transition: all 0.3s;
  }

  .page-top-nav svg {
    width: 32px;
    height: 32px;
    rotate: 90deg;
    transform: all 0.3s;
  }

  .page-top-nav:hover {
    background-color: #707070;
    box-shadow: 1px 1px 10px rgba(0, 0, 0, 0.2);
  }

  .page-top-nav:hover svg {
    filter: invert(100%) sepia(0%) saturate(1152%) hue-rotate(311deg) brightness(99%) contrast(105%);
  }

  .portfolio-detail-wrapper {
    width: 100%;
    padding: 0 20px;
  }

  .profile-grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .profile-info {
    max-width: calc(5/9 * 100vw);
  }
  
  .user-name {
    margin-bottom: 20px;
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: calc(2/45 * 100vw);
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 9.6px;
  }

  .tags {
    margin-bottom: 20px;
  }

  .tag {
    margin-right: 15px;
    color: #000;
    font-family: "Zen Kurenaido";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
  }

  .social-link {
    text-decoration: underline;
    font-size: 0.9rem;
    color: #000;
    margin-right: 15px;
  }

  .icon {
    position: relative;
    height: stretch;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .circle {
    width: calc(5/24 * 100vw);
    height: calc(5/24 * 100vw);
    max-width: 300px;
    max-height: 300px;
    min-width: 170px;
    min-height: 170px;
    background-color: #eee;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .profile-grade {
    color: #000;
    font-family: "Grandiflora One";
    font-size: calc(2/45 * 100vw);
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 9.6px;
    position: absolute;
    bottom: 0px;
    text-align: right;
    right: 0px;
  }

  .camera-info {
    margin-bottom: 20px;
    color: #000;
    font-family: "Zen Kurenaido";
    font-size: calc(1/72 * 100vw);
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
  }

  .self-introduction {
    white-space: pre-line;
    color: #000;
    font-family: "Zen Kurenaido";
    font-size: calc(1/72 * 100vw);
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
  }

  .profile-icon {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid #ddd;
  }

  .icon .suffix {
    position: absolute;
    right: 10px;
    bottom: 0px;
    line-height: 1.1;
    font-size: 3rem;
    font-family: "Courier New", monospace;
    padding: 4px 8px;
    border-radius: 3px;
    text-align: center;
  }

  .section-divider {
    border: none;
    border-top: 1px solid #000;
    margin: 40px 0;
  }

  .gallery-container-inner {
    width: stretch;
    padding: 0 20px;
  }

  .picture-grid {
    width: stretch;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .photo-card {
    width: 100%;
    width: stretch;
    opacity: 1;
    transition: opacity 0.5s ease;
    cursor: pointer;
    overflow: hidden;
  }

  .photo-wrapper {
    width: 100%;
  }

  .photo-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
  }
  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  .modal-close {
    position: fixed;
    top: 20px;
    right: 20px;
    color: white;
    font-size: 50px;
    background: none;
    border: none;
    cursor: pointer;
  }
  #modal-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
  }

  .back-link {
    margin-top: 48px;
    font-family: "Zen Kurenaido";
    font-size: 20px;
    letter-spacing: 3px;
    text-align: right;
    color: #6f6f6f;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 15px;
  }

  .back-link:hover {
    color: #0db49b;
  }

  @media (max-width: 1200px) {
    .gallery-container-inner,
    .picture-grid {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .section-title h1 {
      font-size: 48px;
      letter-spacing: 7.2px;
      padding-right: 39px;
    }

    .page-top-nav {
      width: 35px;
      height: 35px;
    }

    .page-top-nav svg {
      width: 22px;
      height: 22px;
    }

    .profile-grid {
      flex-direction: column;
      align-items: center;
    }

    .profile-info {
      max-width: 100%;
    }

    .tag {
      font-size: 16px;
      margin-left: 15px;
      margin-right: 0;
    }

    .tags {
      text-align: right;
    }

    .profile-grade {
      font-size: 24px;
      position: static;
      transform: none;
      margin-top: 10px;
      text-align: center;
    }

    .user-name {
      font-size: 40px;
      letter-spacing: 4px;
      text-align: center;
    }

    .camera-info,
    .self-introduction {
      font-size: 16px;
    }

    .icon {
      order: -1;
      margin-bottom: 30px;
    }

    .picture-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .back-link {
      font-size: 12px;
      letter-spacing: 2px;
    }
  }
</style>
