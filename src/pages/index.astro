    (() => {
      console.log("carousel found",
        document.querySelectorAll(".photo-carousel-contents").length
      );

      console.log("carousel start");
      console.log(carousel.length);

      const carousels =document.querySelector(".photo-carousel-contents");
      const lists = carousels.querySelectorAll("ul");

      console.log(lists[0].scrollWidth);
      console.log(lists[0].offsetLeft);
      console.log(lists[1].offsetLeft);
      
      const carousel = Array.from(
        document.querySelectorAll(".photo-carousel-contents"),
      );
      if (carousels.length === 0) return;

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );
      const minWidth = 140;
      const maxWidth = 240;
      const aspectRatio = 180 / 240;
      const speedPxPerSec = 30;

      const attachCarousel = (carousel) => {
        const lists = Array.from(carousel.querySelectorAll("ul"));
        if (lists.length < 2) return;

        let listWidth = 0;
        let offset = 0;
        let lastTime = 0;
        let rafId = 0;
        let baseOffsetA = 0;
        let baseOffsetB = 0;
        let gap = 0;

        const updateItemSize = () => {
          const containerWidth = carousel.clientWidth || window.innerWidth;
          const itemWidth = Math.round(
            Math.max(minWidth, Math.min(maxWidth, containerWidth * 0.28)),
          );
          const itemHeight = Math.round(itemWidth * aspectRatio);

          carousel.querySelectorAll(".photo-carousel-content").forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            node.style.width = `${itemWidth}px`;
            node.style.height = `${itemHeight}px`;
          });

          carousel.querySelectorAll("ul li").forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            node.style.width = `${itemWidth}px`;
            node.style.minWidth = `${itemWidth}px`;
          });
        };

        const measure = () => {
          const styles = getComputedStyle(carousel);
          gap = parseFloat(styles.columnGap || styles.gap || "0");
          listWidth = lists[0].scrollWidth;
          baseOffsetA = lists[0].offsetLeft;
          baseOffsetB = lists[1].offsetLeft;
        };

        const render = () => {
          lists[0].style.transform = `translateX(${offset - baseOffsetA}px)`;
          lists[1].style.transform = `translateX(${offset + listWidth + gap - baseOffsetB}px)`;
        };

        const step = (timestamp) => {
          if (prefersReducedMotion.matches) return;
          if (!lastTime) lastTime = timestamp;
          const delta = (timestamp - lastTime) / 1000;
          lastTime = timestamp;
          offset -= speedPxPerSec * delta;
          if (listWidth > 0 && Math.abs(offset) >= listWidth + gap) {
            offset += listWidth + gap;
          }
          render();
          rafId = requestAnimationFrame(step);
        };

        const refresh = () => {
          updateItemSize();
          measure();
          offset = 0;
          lastTime = 0;
          render();
        };

        refresh();

        if (!prefersReducedMotion.matches) {
          rafId = requestAnimationFrame(step);
        }

        window.addEventListener("resize", () => {
          refresh();
        });

        if (typeof prefersReducedMotion.addEventListener === "function") {
          prefersReducedMotion.addEventListener("change", () => {
            cancelAnimationFrame(rafId);
            lastTime = 0;
            if (!prefersReducedMotion.matches) {
              rafId = requestAnimationFrame(step);
            }
          });
        }
      };

      carousels.forEach((carousel) => {
        if (carousel instanceof HTMLElement) {
          attachCarousel(carousel);
        }
      });
    })();

