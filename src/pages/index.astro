---
import Layout from "../layouts/Layout.astro";
import "../styles/UA+reset.css";
import { microcmsClient } from "../lib/microcms";
import type { Blog } from "../types/microcms";
import {
  buildTabs,
  formatDate,
  getPublishedDate,
  normalizeTags,
} from "../utils/blog";
import { linkToPost } from "../utils/linkToPost";

import MainPhoto1 from "../assets/header/Photo1.jpeg";
import MainPhoto2 from "../assets/header/Photo2.jpg";
import MainPhoto3 from "../assets/header/Photo3.jpeg";

import ADphoto1 from "../assets/advertising/Photo1.jpeg";
import ADphoto2 from "../assets/advertising/Photo2.jpeg";
import ADphoto3 from "../assets/advertising/Photo3.jpeg";
import ADphoto4 from "../assets/advertising/Photo4.jpeg";
import ADphoto5 from "../assets/advertising/Photo5.jpeg";

const { contents: posts } = await microcmsClient.getList<Blog>({
  endpoint: "blog",
  queries: {
    limit: 100,
    orders: "-publishedAt",
    depth: 2,
  },
});

const tabs = buildTabs(posts);
const tabPostLimit = 3;

const response = await microcmsClient.getList({
  endpoint: "card_image",
  queries: { limit: 100 },
});
const cardImages = response.contents;

const fixedTexts = [
  {
    title: "Scharade",
    text: "〜活動内容紹介〜",
    slug: "",
    image: `<svg xmlns="http://www.w3.org/2000/svg" width="78" height="59" viewBox="0 0 78 59" fill="none">
              <path d="M38.875 52.5666C47.0972 52.5666 53.7626 45.8782 53.7626 37.6278C53.7626 29.3773 47.0972 22.689 38.875 22.689C30.6528 22.689 23.9875 29.3773 23.9875 37.6278C23.9875 45.8782 30.6528 52.5666 38.875 52.5666Z" stroke="white" />
              <path d="M38.875 57.6369C48.1795 57.6369 64.2629 57.6634 73.578 57.6104C76.1106 57.5821 76.6637 57.0237 76.6337 54.4063C76.6478 44.9709 76.6672 23.4295 76.6249 13.9021C76.5826 12.8329 76.5474 11.8185 75.658 11.2671C74.8831 10.7299 72.4649 10.6927 71.063 10.6821C68.8632 10.6627 65.9414 10.6786 63.4316 10.6715C61.2618 10.6645 59.4478 10.6185 58.2378 10.0866C54.1659 8.44123 57.4682 1.3138 52.262 1.1141C44.5849 0.925004 33.1616 1.01337 25.8526 1.07876C23.1931 1.13884 22.3478 2.57741 22.0501 4.87487C21.6961 7.91635 21.0814 10.2633 17.5749 10.5372C14.299 10.8076 10.4701 10.615 7.2013 10.6768C5.56865 10.7281 3.77397 10.5973 2.26637 11.1293C1.01767 11.6312 1.0617 12.9831 1.01239 14.2185C1.00358 25.4336 0.996536 46.8954 1.00182 57.6369" stroke="white" />
              <path d="M38.912 57.5644C28.6195 57.681 19.6918 49.2352 19.1617 38.9708C18.024 24.0762 34.051 13.2251 47.3658 19.7482C54.2205 23.0194 58.6975 29.9188 58.701 37.7072" stroke="white" />
            </svg>`,
  },
  { title: "定例会", text: "月に2回、E212の部室にて定例会を行なっています！定例会ではカメラ講習、ボドゲ大会などを行なっています。", slug: "" },
  { title: "撮影会", text: "月に２回、東京近辺で撮影会を行なっています！神楽坂撮影会、星空ドライブ撮影会、ディズニー撮影会など。", slug: "" },
  { title: "展示", text: "年に5回、学生会館や外部のスペースを借りて展示を行なっています！自分の作品を多くの方に見てもらえるので技術の向上になります。", slug: "" },
  { title: "夏合宿", text: "8月~9月頃に1泊2日か2泊3日の合宿を行います！2025年には石川・富山、2024年には熱海・伊東に行きました。", slug: "" },
  { title: "春合宿", text: "2月~3月頃に1泊2日か2泊3日の合宿を行います！2025年には宮城・福島、2024年には長野に行きました。", slug: "" },
  { title: "新歓", text: "4月~5月は新入生歓迎企画（以後新歓）を行います！ビラを配ったり食事会をしたりなど、色々な人と話せるいい機会になります。", slug: "" },
  { title: "部室", text: "学生会館のE224に部室があります！2階にあるためとてもアクセスがよく、過ごしやすい空間になっています。詳しくはAbout usの方へ。", slug: "" },
];

const cardRows = [];
const columnCount = 4;

for (let i = 0; i < cardImages.length; i += columnCount) {
  cardRows.push(cardImages.slice(i, i + columnCount));
}
---

<Layout>
  <Fragment slot="setting-none">
    <div class="main-visual a-anchor">
      <div class="main-visual-logo">
        <img src="../src/assets/header/logo.png" alt="Logo" />
      </div>
      <div class="main-visual-photos">
        <a
          href={MainPhoto1.src}
          class="main-visual-photo1"
          data-lightbox="main-photo"
          ><img
            loading="lazy"
            src={MainPhoto1.src}
            alt="写団シャレードの活動写真1"
          /></a
        >
        <a
          href={MainPhoto2.src}
          class="main-visual-photo2"
          data-lightbox="main-photo"
          ><img
            loading="lazy"
            src={MainPhoto2.src}
            alt="写団シャレードの活動写真2"
          /></a
        >
        <a
          href={MainPhoto3.src}
          class="main-visual-photo3"
          data-lightbox="main-photo"
          ><img
            loading="lazy"
            src={MainPhoto3.src}
            alt="写団シャレードの活動写真3"
          /></a
        >
        <div class="click-popup">
          <div class="arrow-line">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="55"
              height="37"
              viewBox="0 0 55 37"
              fill="none"
            >
              <path
                d="M5.21777 1.54999C5.21777 1.54999 17.5 31.5 52 31.5"
                stroke="black"
                stroke-width="0.5"></path>
              <line
                x1="4.2466"
                y1="0.799721"
                x2="6.2466"
                y2="12.7997"
                stroke="black"
                stroke-width="0.5"></line>
              <line
                x1="4.13525"
                y1="0.630564"
                x2="14.6733"
                y2="7.4092"
                stroke="black"
                stroke-width="0.5"></line>
            </svg>
          </div>
          <p>click!!</p>
        </div>
      </div>
    </div>
    <div class="slogan">
      <picture class="slogan-line line-1">
        <source media="(min-width: 768px)" srcset="/icons/Line-1.svg" />
        <img src="/icons/Line-2.svg" alt="SVGの代替テキスト">
      </picture>
      <h1 class="slogan-text">
        <span>私たちと一緒に</span><span>一生に残る素敵な思い出を</span><span>写真に残しませんか？</span>
      </h1>
      <p class="slogan-subtext">
        Shall we create and capture beautiful memories together?
      </p>
      <picture class="slogan-line line-2">
        <source media="(min-width: 768px)" srcset="/icons/Line-1.svg" />
        <img src="/icons/Line-2.svg" alt="SVGの代替テキスト">
      </picture>
    </div>

    <div class="section-title">
      <h1>Activity</h1>
      <div class="section-title-line"></div>
    </div>
    <div class="Activity">
      <div class="tab">
        {
          tabs
            .sort((a, b) => {
              if (a.label === "Others") return 1;
              if (b.label === "Others") return -1;
              return 0;
            })
            .map((tab, index) => {
              const inputId = `home-tab-${tab.slug}`;
              return [
                <input
                  type="radio"
                  id={inputId}
                  name="home-tab"
                  checked={index === 0}
                />,
                <label for={inputId}>{tab.label}</label>,
                <div class="tab-panel">
                  {tab.posts.length ? (
                    tab.posts.slice(0, tabPostLimit).map((post, postIndex) => (
                      <article
                        class={`Activity-item Activity-item-${postIndex + 1}`}
                      >
                        <a href={linkToPost(post.slug, "home")}>
                          <div class="Activity-info">
                            <p class="Activity-date">
                              {formatDate(getPublishedDate(post))}
                            </p>
                            {normalizeTags(post.tags).map((tag) => (
                              <span class="Activity-tag">#{tag}</span>
                            ))}
                          </div>
                          <h2 class="Activity-title">{post.title}</h2>
                          <div class="Activity-excerpt-container">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="25"
                              height="25"
                              viewBox="0 0 25 25"
                            >
                              <path
                                fill="currentColor"
                                d="m14 20l-.713-.713l3.792-3.787H6V5h1v9.5h10.079l-3.792-3.792l.707-.714L19 15z"
                              />
                            </svg>
                            {post.excerpt ? (
                              <p class="Activity-excerpt">{post.excerpt}</p>
                            ) : null}
                          </div>
                        </a>
                      </article>
                    ))
                  ) : (
                    <p class="Activity-empty">該当する記事はまだありません。</p>
                  )}
                </div>,
              ];
            })
        }
        <a class="view-more-button" href="/Activity">View more</a>
      </div>
      <div class="activity-table">
        <div class="activity-table-grid">
          {
            cardRows.flat().map((card, slotIndex) => {
              const textData = fixedTexts[slotIndex];

              return (
                <div
                  class="activity-card"
                  id={`card-${slotIndex + 1}`}
                  style={`background-image: url(${card.image?.url});`}
                >
                  <div class="activity-card-contents">
                    {textData?.image ? (
                      <div set:html={textData.image} style="display: contents;" />
                    ) : null}

                    {textData?.title && <h1>{textData.title}</h1>}
                    {textData?.text && (
                      <p class="activity-card-meta">{textData.text}</p>
                    )}
                  </div>

                  {textData?.slug ? (
                    <a
                      class="activity-card-link"
                      href={textData.slug}
                      aria-label={`${textData.title || "詳細"} ページ`}
                    />
                  ) : null}
                </div>
              );
            })
          }
        </div>

        <div class="click-popup-2">
          <div class="arrow-line-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="66"
              height="61"
              viewBox="0 0 66 61"
              fill="none"
            >
              <path
                d="M23.9242 4.29224C23.9242 4.29224 17.23 35.9631 45.7531 55.3713"
                stroke="black"
                stroke-width="0.5"></path>
              <line
                x1="23.5433"
                y1="3.12574"
                x2="18.4461"
                y2="14.172"
                stroke="black"
                stroke-width="0.5"></line>
              <line
                x1="23.5464"
                y1="2.92325"
                x2="28.4454"
                y2="14.4558"
                stroke="black"
                stroke-width="0.5"></line>
            </svg>
          </div>
          <p>select!!</p>
        </div>
      </div>
      <div class="activity-table-text">
        <a href="Contact">
          <p><span>撮影依頼も承っております。</span><span>御依頼はこちらから。</span></p>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="25"
            height="25"
            viewBox="0 0 25 25"
            ><path
              fill="currentColor"
              d="m6.05 19l5-7l-5-7H8.5l5 7l-5 7zM12 19l5-7l-5-7h2.45l5 7l-5 7z"
            ></path></svg
          >
        </a>
      </div>
    </div>
    <div class="advertising">
      <div class="section-title how-to-join-title">
          <h1>How&nbsp;to&nbsp;join</h1>
          <div class="section-title-line"></div>
      </div>
      <h1 class="advertising-title">
        あなたの大学生活を、<br />あなたの目線で「写真」に残してみませんか？
      </h1>
      <div class="photo-carousel">
        <div class="click-popup-3">
          <div class="arrow-line-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="61"
              height="45"
              viewBox="0 0 61 45"
              fill="none"
            >
              <path
                d="M11.3237 42.7844C11.3237 42.7844 18.375 11.1911 52.3801 5.36849"
                stroke="black"
                stroke-width="0.5"></path>
              <line
                y1="-0.25"
                x2="12.1655"
                y2="-0.25"
                transform="matrix(-0.00443593 -0.99999 -0.99999 0.00443593 10.2432 43.689)"
                stroke="black"
                stroke-width="0.5"></line>
              <line
                y1="-0.25"
                x2="12.53"
                y2="-0.25"
                transform="matrix(0.737656 -0.675176 -0.675176 -0.737656 10.2432 43.689)"
                stroke="black"
                stroke-width="0.5"></line>
            </svg>
          </div>
          <p>click!!</p>
        </div>
        <div class="upper-film-hole">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="17"
            height="22"
            viewBox="0 0 17 22"
            fill="none"
          >
            <path
              d="M1.40333 5.38588C1.44842 5.23548 1.41886 5.73754 1.48621 5.40416C1.49076 5.47368 1.49545 5.54363 1.5 5.61314C1.47506 5.63077 1.45018 5.64884 1.42524 5.66647C1.41789 5.57311 1.41055 5.47971 1.4032 5.38588C1.40324 5.38588 1.40328 5.38588 1.40333 5.38588ZM1.09096 5.2584C1.1621 5.34396 1.18107 5.6158 1.24672 5.32214C1.2223 5.2988 1.19789 5.27489 1.17348 5.25154C1.19241 5.14959 1.21134 5.04701 1.23018 4.94505C1.22087 4.90838 1.21155 4.87176 1.20235 4.8351C1.24477 4.7884 1.28731 4.74213 1.32984 4.69543C1.32363 4.73689 1.31732 4.77891 1.31111 4.82037C1.34556 4.98427 1.35498 5.1301 1.3614 5.35261C1.37143 5.33307 1.38139 5.31349 1.39142 5.29395C1.37435 5.40688 1.35723 5.51974 1.34016 5.63219C1.3234 5.53453 1.30476 5.42534 1.28913 5.33483C1.22261 5.47967 1.25964 5.73512 1.27351 5.86809C1.29245 6.04916 1.26082 6.00824 1.27406 6.14259C1.27613 6.16403 1.30092 6.16647 1.30134 6.20887C1.30331 6.42283 1.29017 6.83838 1.23231 6.59535C1.23976 6.24321 1.19331 5.94288 1.21028 5.5974C1.14339 5.68879 1.12062 5.50679 1.09096 5.2584ZM1.30396 11.7276C1.27148 11.6209 1.28459 11.4035 1.30714 11.2563C1.30714 11.2561 1.30714 11.2559 1.30714 11.2558C1.31211 11.2234 1.35528 11.15 1.35352 11.2558C1.35051 11.4282 1.28254 11.5116 1.32868 11.6021C1.32009 11.6426 1.31245 11.6852 1.30396 11.7276ZM1.30799 12.1024C1.29133 12.2082 1.24012 12.1602 1.25398 12.0277C1.25394 12.0277 1.2539 12.0277 1.25386 12.0277C1.25965 11.9724 1.30013 12.081 1.25905 11.8827C1.29101 11.8422 1.32009 11.8024 1.35102 11.7624C1.35154 11.8109 1.35238 11.8552 1.35279 11.9061C1.30025 11.8718 1.32452 11.9966 1.30799 12.1024ZM1.26124 6.77412C1.30851 6.79076 1.30821 6.72109 1.34101 6.60246C1.33946 6.71443 1.3378 6.82642 1.33625 6.93791C1.31122 6.88313 1.28628 6.8289 1.26124 6.77412ZM1.26857 4.14364C1.26857 4.14347 1.26857 4.1433 1.26857 4.14313C1.26112 4.10644 1.25364 4.06965 1.24629 4.03343C1.26316 4.01151 1.27995 3.98984 1.29682 3.96792C1.28099 3.83831 1.26516 3.708 1.24922 3.57839C1.30075 3.59413 1.29236 3.82679 1.3