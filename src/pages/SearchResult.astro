---
import Layout from "../layouts/Layout.astro";
import "../styles/UA+reset.css";
import { microcmsClient, getPortfolios } from "../lib/microcms";
import { getAlbums } from "../lib/lightroom";
import type { Blog } from "../types/microcms";
import { linkToPost } from "../utils/linkToPost";

const rawPages = import.meta.glob("./**/*.astro", { as: "raw", eager: true });

const stripFrontmatter = (source: string) =>
  source.replace(/^---[\s\S]*?---/, "");

const stripTags = (source: string) =>
  source
    .replace(/<script[\s\S]*?<\/script>/gi, " ")
    .replace(/<style[\s\S]*?<\/style>/gi, " ")
    .replace(/<!--[\s\S]*?-->/g, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const normalizeContent = (parts: Array<string | null | undefined>) =>
  parts
    .filter((part): part is string => Boolean(part && part.trim()))
    .join(" ")
    .replace(/\s+/g, " ")
    .trim();

const buildExcerpt = (content: string) =>
  content.length > 180 ? `${content.slice(0, 180)}...` : content;

type SearchEntry = {
  title: string;
  url: string;
  content: string;
  excerpt: string;
};

const pathToRoute = (filePath: string) => {
  const normalized = filePath.replace(/^\.\/?/, "").replace(/\\/g, "/");
  if (normalized === "index.astro") return "/";
  if (normalized.endsWith("/index.astro")) {
    return `/${normalized.slice(0, -"/index.astro".length)}`;
  }
  return `/${normalized.replace(/\.astro$/, "")}`;
};

const getFallbackTitle = (route: string) => {
  if (route === "/") return "Home";
  const lastSegment = route.split("/").filter(Boolean).pop() ?? route;
  return lastSegment.replace(/[-_]/g, " ");
};

const getTitle = (source: string, fallback: string) => {
  const match = source.match(/<h1[^>]*>([\s\S]*?)<\/h1>/i);
  if (!match) return fallback;
  const text = stripTags(match[1]);
  return text || fallback;
};

const staticIndex: SearchEntry[] = Object.entries(rawPages)
  .filter(
    ([path]) =>
      !path.includes("/SearchResult.astro") &&
      !path.includes("/404.astro") &&
      !path.includes("/[")
  )
  .map(([path, raw]) => {
    const route = pathToRoute(path);
    const body = stripTags(stripFrontmatter(raw));
    const title = getTitle(raw, getFallbackTitle(route));
    const excerpt = buildExcerpt(body);
    return { title, url: route, content: body, excerpt };
  })
  .filter((entry) => entry.content);

let portfolioEntries: SearchEntry[] = [];
try {
  const portfolioResponse = await getPortfolios({
    fields: [
      "id",
      "name",
      "self_introduction",
      "hashtags",
      "camera",
      "grade",
      "generation",
    ],
    limit: 100,
  });

  portfolioEntries = portfolioResponse.contents
    .map((portfolio) => {
      const content = normalizeContent([
        portfolio.name,
        portfolio.self_introduction,
        portfolio.camera,
        portfolio.grade,
        portfolio.generation ? `${portfolio.generation}期生` : "",
        ...(portfolio.hashtags ?? []).map((tag) => `#${tag}`),
      ]);
      return {
        title: `Portfolio | ${portfolio.name}`,
        url: `/portfolio/${portfolio.id}`,
        content,
        excerpt: buildExcerpt(content),
      };
    })
    .filter((entry) => entry.content);
} catch (error) {
  console.error("[SearchResult] Failed to load portfolio entries:", error);
}

let blogEntries: SearchEntry[] = [];
try {
  const { contents: posts } = await microcmsClient.getList<Blog>({
    endpoint: "blog",
    queries: {
      limit: 100,
      orders: "-publishedAt",
      depth: 1,
    },
  });

  blogEntries = posts
    .map((post) => {
      const bodyText = stripTags(post.body ?? "");
      const excerptText = stripTags(post.excerpt ?? "");
      const content = normalizeContent([
        post.title,
        excerptText,
        bodyText,
        ...(post.tags ?? []).map((tag) => `#${tag}`),
      ]);
      const excerpt = excerptText || buildExcerpt(bodyText || content);
      return {
        title: post.title,
        url: linkToPost(post.slug),
        content,
        excerpt,
      };
    })
    .filter((entry) => entry.content);
} catch (error) {
  console.error("[SearchResult] Failed to load blog entries:", error);
}

let galleryEntries: SearchEntry[] = [];
try {
  const albums = await getAlbums();
  galleryEntries = albums
    .map((album) => {
      const year = album.created
        ? new Date(album.created).getFullYear()
        : null;
      const title = album.payload?.name
        ? `Gallery | ${album.payload.name}`
        : "Gallery";
      const content = normalizeContent([
        album.payload?.name,
        year ? `${year}` : null,
        "Gallery",
      ]);
      return {
        title,
        url: `/Gallery/${album.id}`,
        content,
        excerpt: buildExcerpt(content),
      };
    })
    .filter((entry) => entry.content);
} catch (error) {
  console.error("[SearchResult] Failed to load gallery entries:", error);
}

const searchIndex = [
  ...staticIndex,
  ...portfolioEntries,
  ...galleryEntries,
  ...blogEntries,
].filter((entry) => entry.content);

---

<Layout>
  <Fragment slot="main-slot">
    <div class="section-title">
      <h1>Search</h1>
      <div class="section-title-line"></div>
    </div>
  </Fragment>
  <Fragment slot="menu-slot">
    <div class="menu-contents-inner">
      <a href="#" class="page-top-nav">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
        >
          <path
            fill="currentColor"
            d="M16 21.308L6.692 12L16 2.692l1.064 1.064L8.819 12l8.244 8.244z"
          ></path>
        </svg>
      </a>
    </div>
  </Fragment>
  <Fragment slot="body-slot">
    <div class="search-results">
      <div class="search-summary-container">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="M9.5 16q-2.725 0-4.612-1.888T3 9.5t1.888-4.612T9.5 3t4.613 1.888T16 9.5q0 1.1-.35 2.075T14.7 13.3l5.6 5.6q.275.275.275.7t-.275.7t-.7.275t-.7-.275l-5.6-5.6q-.75.6-1.725.95T9.5 16m0-2q1.875 0 3.188-1.312T14 9.5t-1.312-3.187T9.5 5T6.313 6.313T5 9.5t1.313 3.188T9.5 14"/></svg>
        <p id="search-summary" class="search-summary"></p>
      </div>
      <ul id="search-list" class="search-list"></ul>
    </div>
  </Fragment>
</Layout>

<script is:inline define:vars={{ SEARCH_INDEX: searchIndex }}>
  (() => {
    const params = new URLSearchParams(window.location.search);
    const rawQuery = params.get("q") || "";
    const query = rawQuery.trim();
    const summaryEl = document.getElementById("search-summary");
    const listEl = document.getElementById("search-list");
    if (!summaryEl || !listEl) return;

    if (!query) {
      summaryEl.textContent = "検索ワードを入力してください。";
      return;
    }

    const tokens = query.toLowerCase().split(/\s+/).filter(Boolean);
    const results = SEARCH_INDEX.filter((item) => {
      const haystack = `${item.title} ${item.content}`.toLowerCase();
      return tokens.every((token) => haystack.includes(token));
    });

    summaryEl.textContent = `「${query}」の検索結果：${results.length}件`;

    if (results.length === 0) {
      const li = document.createElement("li");
      li.className = "search-empty";
      li.textContent = "該当するページが見つかりませんでした。";
      listEl.appendChild(li);
      return;
    }

    results.forEach((item) => {
      const li = document.createElement("li");
      li.className = "search-item";

      const link = document.createElement("a");
      link.href = item.url;

      // タイトル
      const title = document.createElement("h1");
      title.textContent = item.title;
      link.appendChild(title);

      // 抜粋
      if (item.excerpt) {
        // svgとpをまとめるラッパー
        const wrapper = document.createElement("div");
        wrapper.className = "search-excerpt-wrapper";

        // SVG
        const svgNS = "http://www.w3.org/2000/svg";
        const svg = document.createElementNS(svgNS, "svg");
        svg.setAttribute("xmlns", svgNS);
        svg.setAttribute("width", "25");
        svg.setAttribute("height", "25");
        svg.setAttribute("viewBox", "0 0 25 25");

        const path = document.createElementNS(svgNS, "path");
        path.setAttribute("fill", "currentColor");
        path.setAttribute(
          "d",
          "m14 20l-.713-.713l3.792-3.787H6V5h1v9.5h10.079l-3.792-3.792l.707-.714L19 15z"
        );

        svg.appendChild(path);

        // p
        const excerpt = document.createElement("p");
        excerpt.className = "search-excerpt";
        excerpt.textContent = item.excerpt;

        // wrapperに追加
        wrapper.appendChild(svg);
        wrapper.appendChild(excerpt);

        // aタグに追加
        link.appendChild(wrapper);
      }

      li.appendChild(link);
      listEl.appendChild(li);
    });
  })();
</script>

<style>
  .section-title {
    display: flex;
    align-items: center;
    margin-bottom: 55px;
  }
  .section-title h1 {
    font-family: "Didot", serif;
    font-size: 80px;
    letter-spacing: 14.4px;
    padding-right: 50px;
    margin: 0;
  }
  .section-title-line {
    flex-grow: 1;
    height: 1px;
    background: #000;
  }

  .menu-contents-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .page-top-nav {
    width: 50px;
    height: 50px;
    background-color: #fff;
    border: 1px solid #000;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: sticky;
    bottom: 50px;
    z-index: 5;
    transition: all 0.3s;
  }

  .page-top-nav svg {
    width: 32px;
    height: 32px;
    rotate: 90deg;
    transition: all 0.3s;
  }

  .page-top-nav:hover {
    background-color: #707070;
    box-shadow: 1px 1px 10px rgba(0, 0, 0, 0.2);
  }

  .page-top-nav:hover svg {
    filter: invert(100%) sepia(2%) saturate(1%) hue-rotate(267deg) brightness(101%) contrast(101%);
  }

  .search-results {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  .search-summary-container {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid #000;
    padding-bottom: 8px;
  }

  .search-summary {
    margin: 0;
    font-family: "Zen Old Mincho", serif;
    font-size: 28px;
    letter-spacing: 2px;
  }

  .search-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    counter-reset: search-item;
    gap: 20px;
  }

  :global(.search-item) {
    padding: 20px 20px 20px 30px;
    position: relative;
    counter-increment: search-item;
    border-left: 20px solid #d2d2d2;
  }

  :global(.search-item)::before {
    content: counter(search-item);
    position: absolute;
    bottom: -23px;
    left: -20px;
    font-size: 84px;
    font-family: "Grandiflora One";
    color: #fff;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  }

  :global(.search-item:not(:last-child))::after {
    content: "";
    position: absolute;
    left: 35%;
    bottom: 0;
    width: 30%;
    height: 1px;
    background: #000;
  }

  :global(.search-item) a {
    text-decoration: none;
    color: #000;
    font-family: "Zen Old Mincho", serif;
    font-size: 24px;
    letter-spacing: 2px;
  }

  :global(.search-item:hover) {
    background-color: #f0f0f0;
  }

  :global(.search-item a h1) {
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
    margin-bottom: 12px;
  }

  :global(.search-excerpt-wrapper) {
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 8px;
  }

  ::global(.search-excerpt-wrapper svg) {
    flex-shrink: 0;
    width: 25px;
    height: 25px;
    color: #444;
  }

  :global(.search-excerpt) {
    margin: 0px;
    font-family: "Zen Kurenaido";
    font-size: 15px;
    line-height: 1.7;
    letter-spacing: 0.5px;
    color: #333;
  }

  .search-empty {
    color: #444;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .section-title {
      margin-bottom: 10px;
    }
    .section-title h1 {
      font-size: 40px;
      letter-spacing: 8px;
    }

    .page-top-nav {
      width: 35px;
      height: 35px;
    }

    .page-top-nav svg {
        width: 22px;
        height: 22px;
    }

    .search-summary-container {
      gap: 8px;
    }

    .search-summary-container svg {
      width: 22px;
      height: 22px;
    }

    .search-summary {
      font-size: 18px;
    }

    :global(.search-item) {
      padding: 7px 7px 7px 15px;
    }

    :global(.search-item a h1) {
      font-size: 16px;
    }

    :global(.search-excerpt-wrapper) {
      height: stretch;
      overflow: hidden;
    }

    :global(.search-excerpt-wrapper svg) {
      width: 18px;
      height: 18px;
    }

    :global(.search-excerpt) {
      font-size: 12px;
    }

    :global(.search-item)::before {
      bottom: -15px;
      font-size: 60px;
    }
  }
</style>
