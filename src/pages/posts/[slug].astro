---
import MypostLayout from "../../layouts/Mypost_Layout.astro";
import "../../styles/UA+reset.css";
import { microcmsClient } from "../../lib/microcms";
import type { Blog } from "../../types/microcms";
import { formatDate, getPublishedDate } from "../../utils/blog";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

// slugで投稿を検索
const { contents } = await microcmsClient.getList<Blog>({
  endpoint: "blog",
  queries: {
    filters: `slug[equals]${slug}`,
    limit: 1,
    depth: 2,
  },
});

if (contents.length === 0) {
  return Astro.redirect("/404");
}

const post = contents[0];

const formattedDate = formatDate(getPublishedDate(post));
const backLinkMap = {
  activity: { href: "/Activity", label: "Activityへ戻る" },
  gallery: { href: "/Gallery", label: "Galleryへ戻る" },
} as const;
type BackLinkMap = typeof backLinkMap;
type FromParam = keyof BackLinkMap;
const isFromParam = (value: string | null): value is FromParam =>
  value === "activity" || value === "gallery";
const fromParam = Astro.url.searchParams.get("from");
const backLink = isFromParam(fromParam) ? backLinkMap[fromParam] : null;
const backLinkMapJSON = JSON.stringify(backLinkMap);
---

<MypostLayout title={post.title} from="Activity">
  <div class="post-header">
    <h1 class="post-title">{post.title}</h1>
    <div class="post-meta">
      {formattedDate ? <p class="post-date">{formattedDate}</p> : null}
      {
        post.tags && post.tags.length > 0 ? (
          <ul class="post-tags">
            {post.tags.map((tag) => (
              <li class="post-tag">#{tag}</li>
            ))}
          </ul>
        ) : null
      }
    </div>
  </div>

  {
    post.pictures?.length ? (
      <div class="post-pictures">
        {post.pictures.map((image) => {
          const tapeNum = Math.floor(Math.random() * 70) + 1;
          const rotateDeg = Math.floor(Math.random() * 41) * 0.5 - 10;

          const tapeStyles = `
            --tape-url: url(/images/tapes/asset${tapeNum}.svg);
            --tape-rotate: ${rotateDeg}deg;
          `;

          return (
            <figure class="post-eyecatch" style={tapeStyles}>
              <img
                src={image.url}
                alt={image.alt || post.title}
                loading="lazy"
              />
            </figure>
          );
        })}
      </div>
    ) : null
  }
  <div class="post-body" set:html={post.body ?? ""} />
  <div
    class="back-link"
    id="post-back-link"
    data-map={backLinkMapJSON}
    hidden={!backLink}
  >
    {
      backLink ? <a href={backLink.href}>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="25"
        height="25"
        viewBox="0 0 20 20"
        ><path
          fill="currentColor"
          d="M11.25 17.308L5.942 12l5.308-5.308l.708.708L7.364 12l4.594 4.6zm6.1 0L12.042 12l5.308-5.308l.708.708l-4.594 4.6l4.594 4.6z"
        ></path>
      </svg>
      {backLink.label}</a> : null
    }
  </div>
</MypostLayout>

<style>
  .post-header {
    margin-bottom: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .post-title {
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: calc(64/1440 * 100vw);
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 9.6px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 12px 24px;
  }

  .post-date {
    margin: 0;
    font-family: "Grandiflora One";
    font-size: 25px;
    letter-spacing: 3px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-tag {
    font-family: "Grandiflora One";
    font-size: 18px;
    letter-spacing: 2px;
  }

  .post-pictures {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .post-eyecatch {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .post-eyecatch::after {
    content: "";
    background-image: var(--tape-url);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    width: 30%;
    height: 5%;
    display: block;
    position: absolute;
    top: -20px;
    left: 35%;
    transform: rotate(var(--tape-rotate));
    z-index: 10 !important;
  }

  .post-eyecatch img {
    width: 100%;
    height: auto;
    display: block;
    border: 20px solid #ffffff;
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
  }

  :global(.post-body *) {
    margin-bottom: 1.5em;
  }

  .post-body :global(h1) {
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: 32px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3.6px;
    margin-top: 1.5em;
  }

  .post-body :global(h2) {
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: 22px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3.3px;
    margin-top: 1em;
    margin-bottom: 1em;
  }

  .post-body :global(h3) {
    color: #000;
    font-family: "Zen Old Mincho";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
  }

  .post-body :global(p) {
    color: #000;
    font-family: "Zen Kurenaido";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
  }

  .post-body :global(ul) {
    list-style-type: disc;
    margin: 0 0 1.5em 5em;
    padding: 0;
  }

  .post-body :global(ol) {
    list-style-type: decimal;
    margin: 0 0 1.5em 5em;
    padding: 0;
  }

  .post-body :global(li) {
    color: #000;
    font-family: "Zen Kurenaido";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 3px;
    margin-bottom: 0.5em;
  }

  .post-body :global(figure) {
    margin: 24px 5px;
    position: relative;
    width: fit-content;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .post-body :global(img) {
    max-width: 100%;
    max-height: 80vh;
    height: auto;
    width: auto;
    aspect-ratio: attr(width) / attr(height) !important;
    display: block;
    margin: 24px auto;
    border: 20px solid #ffffff;
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
    position: relative;
  }

  .post-body :global(.taped-image)::after {
    content: "";
    background-image: var(--tape-url);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    width: 30%;
    height: 5%;
    display: block;
    position: absolute;
    top: -20px;
    left: 35%;
    transform: rotate(var(--tape-rotate));
    z-index: 10 !important;
  }

  :global(iframe) {
    border: 20px solid #ffffff;
  }

  .back-link {
    margin-top: 48px;
    font-family: "Zen Kurenaido";
    font-size: 20px;
    letter-spacing: 3px;
    text-align: right;
    color: #6f6f6f;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 15px;
  }

  .back-link:hover {
    color: #0db49b;
  }

  .back-link a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
  }

  @media screen and (max-width: 780px) {
    .post-header {
      flex-direction: column;
      align-items: flex-end;
      gap: 16px;
      margin-bottom: 0;
    }

    .post-title {
      font-size: 115%;
      letter-spacing: 4.8px;
      white-space: pre-wrap;
      display: inline-block;
    }

    .post-meta {
      gap: 5px 10px;
    }

    .post-date {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .post-tag {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .post-eyecatch img {
      border-width: 10px;
    }

    .post-body :global(p) {
      font-size: 14px;
      letter-spacing: 2px;
    }

    .post-body :global(h1) {
      font-size: 20px;
    }

    .post-body :global(h2) {
      font-size: 18px;
    }

    .post-body :global(h3) {
      font-size: 16px;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      margin-left: 1.5em;
    }

    .post-body :global(li) {
      font-size: 14px;
      letter-spacing: 2px;
    }

    .post-body :global(figure) {
      margin: 16px auto;
    }

    .post-body :global(img) {
      border-width: 10px;
      margin: 0;
      width: stretch;
    }

    .back-link {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .back-link a {
      gap: 8px;
    }

    .back-link a svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<script is:inline type="module">
  const container = document.getElementById("post-back-link");
  if (container) {
    try {
      const map = JSON.parse(container.dataset.map ?? "{}");
      const params = new URLSearchParams(window.location.search);
      const from = params.get("from");
      const link = from && map[from];
      if (link) {
        if (!container.querySelector("a")) {
          const anchor = document.createElement("a");
          anchor.href = link.href;
          anchor.textContent = link.label;
          container.appendChild(anchor);
        }
        container.hidden = false;
      } else {
        container.hidden = true;
      }
    } catch (error) {
      console.error("Failed to render back link", error);
    }
  }

  const postBody = document.querySelector(".post-body");
  if (postBody instanceof HTMLElement) {
    const images = Array.from(postBody.querySelectorAll("img"));

    images.forEach((img) => {
      const wrapper =
        img.closest("figure") ||
        img.parentElement;

      if (!(wrapper instanceof HTMLElement)) return;
      if (wrapper.classList.contains("taped-image")) return;

      const tapeNum = Math.floor(Math.random() * 70) + 1;
      const rotateDeg = Math.floor(Math.random() * 41) * 0.5 - 10;

      wrapper.classList.add("taped-image");
      wrapper.style.setProperty("--tape-url", `url(/images/tapes/asset${tapeNum}.svg)`);
      wrapper.style.setProperty("--tape-rotate", `${rotateDeg}deg`);
    });
  }
</script>
