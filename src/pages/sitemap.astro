---
import Layout from "../layouts/Layout.astro";
import "../styles/UA+reset.css";

const SITE_URL = "https://scharade.jp";

const sections = [
  {
    title: "Main Pages",
    note: "サイト内の基本ページです。",
    items: [
      { label: "Home", href: "/", description: "トップページ" },
      { label: "About us", href: "/About_us", description: "活動紹介" },
      { label: "Activity", href: "/Activity", description: "活動記事一覧" },
      { label: "Gallery", href: "/Gallery", description: "アルバム一覧" },
      { label: "Portfolio", href: "/Portfolio", description: "メンバー一覧" },
      { label: "Contact", href: "/Contact", description: "お問い合わせ" },
      { label: "Disclaimer", href: "/Disclaimer", description: "免責事項・ポリシー" },
    ],
  },
  {
    title: "Search Engine Sitemap",
    note: "検索エンジン向けの XML sitemap は別途自動生成しています。",
    items: [
      {
        label: "sitemap.xml",
        href: `${SITE_URL}/sitemap.xml`,
        description: "公開ページの一覧を機械可読で出力",
      },
      {
        label: "robots.txt",
        href: `${SITE_URL}/robots.txt`,
        description: "クローラ向けの案内",
      },
    ],
  },
];
---

<Layout title="Sitemap | Scharade">
  <Fragment slot="main-slot">
    <div class="section-title">
      <h1>Sitemap</h1>
      <div class="section-title-line"></div>
    </div>
  </Fragment>

  <Fragment slot="menu-slot">
    <div class="menu-contents-inner">
      <a href="#" class="page-top-nav" aria-label="Top">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
        >
          <path
            fill="currentColor"
            d="M16 21.308L6.692 12L16 2.692l1.064 1.064L8.819 12l8.244 8.244z"
          ></path>
        </svg>
      </a>
    </div>
  </Fragment>

  <Fragment slot="body-slot">
    <div class="intro-block">
      <p>
        このページは公開用のサイトマップです。検索エンジン向けの XML sitemap は別で自動生成しています。
      </p>
    </div>

    {sections.map((section) => (
      <div class="sitemap_container">
        <h1>{section.title}</h1>
        <p class="section-note">{section.note}</p>
        <ul class="sitemap-list">
          {section.items.map((item) => (
            <li>
              <a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                <span class="item-label">{item.label}</span>
                <span class="item-description">{item.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </Fragment>
</Layout>

<style>
  .section-title {
    display: flex;
    flex-direction: row;
    align-items: space-between;
    justify-content: center;
    margin-bottom: 55px;
    margin-top: 25px;
  }

  .section-title h1 {
    color: #000;
    font-family: "Didot";
    font-size: 96px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 14.4px;
    padding-right: 78px;
  }

  .section-title-line {
    width: 100%;
    position: relative;
  }

  .section-title-line::after {
    content: "";
    display: block;
    width: 100%;
    height: 1px;
    background: #000;
    position: absolute;
    top: 50%;
    right: 0;
  }

  .menu-contents-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .page-top-nav {
    width: 50px;
    height: 50px;
    background-color: #fff;
    border: 1px solid #000;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: sticky;
    bottom: 50px;
    z-index: 5;
    transition: all 0.3s;
  }

  .page-top-nav svg {
    width: 32px;
    height: 32px;
    rotate: 90deg;
    transition: all 0.3s;
  }

  .page-top-nav:hover {
    background-color: #707070;
    box-shadow: 1px 1px 10px rgba(0, 0, 0, 0.2);
  }

  .page-top-nav:hover svg {
    filter: invert(100%) sepia(2%) saturate(1%) hue-rotate(267deg) brightness(101%) contrast(101%);
  }

  .intro-block,
  .sitemap_container {
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
    margin-top: 15px;
    margin-bottom: 15px;
  }

  .intro-block {
    margin-bottom: 40px;
  }

  .sitemap_container {
    padding-left: 20px;
  }

  .sitemap_container:not(:last-child) {
    margin-bottom: 60px;
  }

  .sitemap_container::after {
    content: "";
    display: block;
    width: 1px;
    background: #000;
    position: absolute;
    top: -15px;
    left: 0;
  }

  .intro-block::after {
    height: calc(100% + 30px);
  }

  .sitemap_container::after {
    height: calc(100% + 30px);
  }

  .intro-block p {
    color: #000;
    font-family: "Zen Kurenaido", sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.8;
    letter-spacing: 2.4px;
    margin: 0;
  }

  .sitemap_container h1 {
    color: #000;
    font-family: "Zen Old Mincho", serif;
    font-size: 32px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 4.8px;
    margin-bottom: 16px;
  }

  .section-note {
    color: #000;
    font-family: "Zen Kurenaido", sans-serif;
    font-size: 16px;
    line-height: 1.8;
    letter-spacing: 2px;
    margin-bottom: 18px;
  }

  .sitemap-list {
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px 24px;
  }

  .sitemap-list li {
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .sitemap-list a {
    color: #000;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 2px 0;
  }

  .item-label {
    font-family: "Zen Old Mincho", serif;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .item-description {
    font-family: "Zen Kurenaido", sans-serif;
    font-size: 14px;
    letter-spacing: 1.2px;
    line-height: 1.6;
  }

  .sitemap-list a::after {
    content: "";
    height: 1px;
    width: 100%;
    background: #000;
    transform: scale(0, 1);
    transform-origin: center top;
    transition: transform 0.3s;
  }

  .sitemap-list a:hover::after {
    transform: scale(1, 1);
  }

  @media (max-width: 768px) {
    .section-title {
      margin-bottom: 35px;
    }

    .section-title h1 {
      font-size: 48px;
      letter-spacing: 7.2px;
      padding-right: 16px;
    }

    .page-top-nav {
      width: 35px;
      height: 35px;
    }

    .page-top-nav svg {
      width: 22px;
      height: 22px;
    }

    .intro-block,
    .sitemap_container {
      padding-left: 15px;
      margin-top: 12px;
      margin-bottom: 12px;
    }

    .intro-block {
      margin-bottom: 30px;
    }

    .intro-block::after,
    .sitemap_container::after {
      height: calc(100% + 24px);
      top: -12px;
    }

    .sitemap_container h1 {
      font-size: 25px;
      letter-spacing: 3px;
      margin-bottom: 12px;
    }

    .intro-block p,
    .section-note {
      font-size: 14px;
      letter-spacing: 1.6px;
      line-height: 1.7;
    }

    .sitemap-list {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .item-label {
      font-size: 16px;
      letter-spacing: 1px;
    }

    .item-description {
      font-size: 13px;
      letter-spacing: 1px;
    }
  }
</style>