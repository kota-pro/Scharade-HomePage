---
import Layout from "./Layout.astro";
import "../styles/UA+reset.css";
import "../styles/Gallery.css";

const { title = "Gallery" } = Astro.props;
---

<Layout>
  <Fragment slot="main-slot">
    <div class="section-title">
      <h1>{title}</h1>
      <div class="section-title-line"></div>
    </div>      
  </Fragment>
  <Fragment slot="menu-slot">
    <div class="menu-contents-inner">
      <a href="#" class="page-top-nav">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          ><path
            fill="currentColor"
            d="M16 21.308L6.692 12L16 2.692l1.064 1.064L8.819 12l8.244 8.244z"
          ></path></svg
        >
      </a>
    </div>
  </Fragment>
  <Fragment slot="body-slot">
    <div class="gallery-detail-wrapper">
      <slot />
    </div>
  </Fragment>
</Layout>

<style>
  .gallery-detail-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>